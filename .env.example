# AgentFlow 完整环境变量配置
# 复制此文件为 .env 并填入你的 API Key
#
# cp .env.example .env
# vim .env  # 填写至少一个 API Key
# docker compose up -d

# ═══════════════════════════════════════════════════════════
# API 密钥（至少填一个）
# ═══════════════════════════════════════════════════════════
# ZHIPU (GLM 系列)
# ZAI_API_KEY="your_zhipu_ai_key_here"
# ZAI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# DeepSeek (DeepSeek-V3 / DeepSeek-R1)
# DEEPSEEK_API_KEY="your_deepseek_key_here"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# OpenAI (GPT-4o / GPT-4o-mini)
# OPENAI_API_KEY="your_openai_key_here"
# OPENAI_BASE_URL="https://api.openai.com/v1"

# xAI (Grok-3)
# XAI_API_KEY="your_xai_key_here"
# XAI_BASE_URL="https://api.x.ai/v1"

# 阿里通义千问 (Qwen-Max)
# DASHSCOPE_API_KEY="your_dashscope_key_here"
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ═══════════════════════════════════════════════════════════
# 模型选择
# ═══════════════════════════════════════════════════════════
# AGENT_MODEL="deepseek-v4-flash"
# AGENT_MODEL="glm-5-turbo"
# AGENT_MODEL="gpt-4o"

# ═══════════════════════════════════════════════════════════
# 服务配置
# ═══════════════════════════════════════════════════════════
AGENTFLOW_HOST=0.0.0.0
AGENTFLOW_PORT=9600

# ═══════════════════════════════════════════════════════════
# AgentFlow-Code 引擎配置
# ═══════════════════════════════════════════════════════════
# Docker 内：/opt/claude-code-engine
# 本地开发：/home/llw/agentflow-code-engine
AGENTFLOW_CC_ENGINE_DIR=/opt/claude-code-engine
BUN_PATH=/usr/local/bin/bun

# ═══════════════════════════════════════════════════════════
# CORS / Webhook
# ═══════════════════════════════════════════════════════════
# CORS_ORIGINS="*"
# WEBHOOK_BASE_URL="https://your-domain.com"
